<div class="status-container">
    <div class="status-header">
        <h2>System Diagnostics: Entry Point Status</h2>
        <p class="status-subtitle">Real-time infrastructure monitoring and validation</p>
    </div>

    <div class="diagnostics-info">
        <p class="info-text">Diagnostics mode enabled. Subsystem verification in progress...</p>
    </div>

    <% if (systemStatus) { %>
        <div class="system-grid">
            <div class="system-stat">
                <span class="stat-label">STATUS</span>
                <span class="stat-value"><%= systemStatus.status %></span>
            </div>
            <div class="system-stat">
                <span class="stat-label">UPTIME</span>
                <span class="stat-value"><%= systemStatus.uptime %></span>
            </div>
            <div class="system-stat">
                <span class="stat-label">DATABASE</span>
                <span class="stat-value"><%= systemStatus.database %></span>
            </div>
            <div class="system-stat">
                <span class="stat-label">CACHE</span>
                <span class="stat-value"><%= systemStatus.cache %></span>
            </div>
        </div>

        <div class="system-log">
            <p class="log-entry"><span class="timestamp">[2024-01-15 09:32:00]</span> Security audit completed: <%= systemStatus.security_patch %></p>
            <p class="log-entry"><span class="timestamp">[2024-01-14 18:15:22]</span> System backup synchronized</p>
            <p class="log-entry"><span class="timestamp">[2024-01-14 12:00:00]</span> Infrastructure health check passed</p>
        </div>
    <% } %>

    <div class="flag-box">
        <% if (flag) { %>
            <%= flag %>
        <% } else { %>
            <span class="status-normal">Diagnostic Output: Normal</span>
        <% } %>
    </div>

    <p class="info-text">Diagnostic capture complete. Access audit logs for more details.</p>
</div>

<style>
    .status-container {
        text-align: left;
    }

    .status-header h2 {
        margin-bottom: 5px;
    }

    .status-subtitle {
        color: var(--accent-cyan);
        font-size: 0.9rem;
        margin: 0 0 20px 0;
    }

    .info-text {
        color: var(--text-secondary);
        margin: 15px 0;
        font-size: 0.95rem;
    }

    .system-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 15px;
        margin: 25px 0;
        background: rgba(0, 240, 255, 0.02);
        padding: 20px;
        border: 1px solid var(--border-color);
        border-radius: 8px;
    }

    .system-stat {
        display: flex;
        flex-direction: column;
        padding: 12px;
        background: rgba(0, 0, 0, 0.2);
        border-left: 2px solid var(--accent-cyan);
        border-radius: 4px;
    }

    .stat-label {
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: var(--text-secondary);
        margin-bottom: 5px;
    }

    .stat-value {
        font-family: var(--font-mono);
        color: var(--accent-cyan);
        font-weight: 600;
    }

    .system-log {
        background: rgba(0, 0, 0, 0.3);
        border: 1px solid var(--border-color);
        border-radius: 8px;
        padding: 15px;
        margin: 20px 0;
        max-height: 150px;
        overflow-y: auto;
    }

    .log-entry {
        font-size: 0.85rem;
        margin: 8px 0;
        color: var(--text-secondary);
        font-family: var(--font-mono);
    }

    .timestamp {
        color: var(--accent-cyan);
        margin-right: 10px;
    }

    .status-normal {
        color: var(--accent-cyan);
        opacity: 0.7;
    }
</style>
