<h2 style="text-align: center;">System Diagnostics</h2>
<p style="text-align: center; color: var(--terminal-green); font-family: var(--font-mono); margin-bottom: 20px;">Real-time Infrastructure Monitoring</p>

<% if (systemStatus) { %>
    <div class="system-grid">
        <div class="system-stat">
            <span class="stat-label">STATUS</span>
            <span class="stat-value"><%= systemStatus.status %></span>
        </div>
        <div class="system-stat">
            <span class="stat-label">UPTIME</span>
            <span class="stat-value"><%= systemStatus.uptime %></span>
        </div>
        <div class="system-stat">
            <span class="stat-label">DATABASE</span>
            <span class="stat-value"><%= systemStatus.database %></span>
        </div>
        <div class="system-stat">
            <span class="stat-label">CACHE</span>
            <span class="stat-value"><%= systemStatus.cache %></span>
        </div>
    </div>

    <div class="code-block" style="margin: 20px 0;">
        <code><%= systemStatus.last_audit %></code>
    </div>
<% } %>

<div class="flag-box">
    <% if (flag) { %>
        <%= flag %>
    <% } else { %>
        <span style="opacity: 0.7;">DIAGNOSTIC OUTPUT: NORMAL</span>
    <% } %>
</div>

<div class="hint-text">
    💡 <strong>Challenge:</strong> This endpoint requires authentication. Find the auth token parameter to unlock the flag.
</div>
