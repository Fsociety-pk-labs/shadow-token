<h2 style="text-align: center;">User Profile & Session Management</h2>

<% if (flag) { %>
    <div class="success-alert">
        <span class="alert-icon">SUCCESS</span>
        <div>
            <p><strong>Admin Access Granted</strong></p>
            <p style="margin-top: 5px; font-size: 0.9rem;">Session authenticated and verified</p>
        </div>
    </div>
    <div class="flag-box">
        <%= flag %>
    </div>
<% } else { %>
    <div style="background: var(--bg-light); border: 1px solid var(--border-light); padding: 15px; border-radius: 6px; margin-bottom: 20px;">
        <p style="margin: 0; color: var(--text-dark);">Current User: <strong><%= session.user %></strong></p>
        <p style="margin: 8px 0 0 0; color: var(--text-dark);">Access Level: <strong><%= session.access %></strong></p>
    </div>

    <% if (warning) { %>
        <div class="info-alert">
            <span class="alert-icon">INFO</span>
            <p><%= warning %></p>
        </div>
    <% } %>

    <div class="code-block">
        <code><pre><%= JSON.stringify(session, null, 2) %></pre></code>
    </div>

    <div class="hint-text">
        💡 <strong>Challenge:</strong> This session data is Base64-encoded in your browser cookie. Edit it to become an admin with access level 1. Use browser DevTools (F12 → Application → Cookies).
    </div>
<% } %>
