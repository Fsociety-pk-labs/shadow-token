<h2 style="text-align: center;">Session Management Dashboard</h2>

<% if (flag) { %>
    <div class="success-alert">
        <span class="alert-icon">✓</span>
        <div>
            <p><strong>ADMIN ACCESS GRANTED</strong></p>
            <p style="margin-top: 5px; font-size: 0.9rem;">Stage 3 Complete: Insecure Cryptography Exploited</p>
        </div>
    </div>
    <div class="flag-box">
        <%= flag %>
    </div>
<% } else { %>
    <div style="background: rgba(0, 255, 65, 0.05); border: 2px solid var(--terminal-green); padding: 15px; border-radius: 0; margin-bottom: 20px;">
        <p style="margin: 0; color: var(--terminal-green);">Current User: <strong><%= session.user %></strong></p>
        <p style="margin: 8px 0 0 0; color: var(--terminal-green);">Access Level: <strong><%= session.access %></strong></p>
    </div>

    <% if (warning) { %>
        <div class="info-alert">
            <span class="alert-icon">⚠</span>
            <p><%= warning %></p>
        </div>
    <% } %>

    <div class="code-block">
        <code><pre><%= JSON.stringify(session, null, 2) %></pre></code>
    </div>

    <div class="hint-text">
        💡 <strong>Challenge:</strong> This session data is Base64-encoded in your browser cookie. Edit it to become an admin with access level 1. Use browser DevTools (F12 → Application → Cookies).
    </div>
<% } %>
