<h2 class="glitch" data-text="IDENTITY MANAGEMENT" style="text-align: center;">IDENTITY MANAGEMENT</h2>

<% if (flag) { %>
    <div class="success-alert">
        <div style="font-family: 'Share Tech Mono', monospace; font-weight: bold;">[ SESSION PRIVILEGE ESCALATED ]</div>
        <div style="margin-top: 0.5rem; font-size: 0.9rem; opacity: 0.8;">Admin token verified. Decryption sequence complete.</div>
    </div>
    <div class="flag-box">
        <div style="font-size: 0.8rem; color: var(--flag-amber); margin-bottom: 0.5rem; font-weight: bold; animation: pulse 1s infinite;">🚩 FLAG 3/5 CAPTURED!</div>
        <%= flag %>
    </div>
<% } else { %>
    <div class="terminal-block">
        <p style="margin: 0; color: var(--text-main);">Current Identity: <strong style="color: var(--primary-red);"><%= session.user %></strong></p>
        <p style="margin: 8px 0 0 0; color: var(--text-main);">Authorization Rank: <strong style="color: var(--primary-red);"><%= session.access %></strong></p>
    </div>

    <% if (warning) { %>
        <div class="terminal-block" style="border-left: 3px solid var(--terminal-green); color: var(--terminal-green); background: rgba(0, 255, 65, 0.02);">
            <span style="font-weight: bold;">[ LOG ]</span> <%= warning %>
        </div>
    <% } %>

    <div style="margin-top: 2rem;">
        <span class="stat-label" style="margin-bottom: 0.5rem; display: block;">RAW SESSION OBJECT DUMP //</span>
        <div class="terminal-block" style="padding: 1rem; border: 1px solid var(--border-faint); background: #000;">
            <pre style="margin: 0; color: var(--terminal-green); font-size: 0.85rem; overflow-x: auto;"><%= JSON.stringify(session, null, 2) %></pre>
        </div>
    </div>

    <div class="terminal-block" style="margin-top: 2rem; border-left: 3px solid var(--flag-amber); color: var(--flag-amber); font-size: 0.85rem;">
        <span style="font-weight: bold;">[ ANALYST NOTICE ]</span> Session integrity is maintained via Base64-encoded client-side tokens. Discrepancies in Authorization Rank will trigger manual audit.
    </div>
<% } %>
