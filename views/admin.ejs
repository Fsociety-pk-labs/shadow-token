<h2 style="text-align: center; color: var(--primary-red);">⚡ EXECUTIVE CONTROL PANEL ⚡</h2>

<% if (flag) { %>
    <div class="success-alert">
        <span class="alert-icon">✓</span>
        <div>
            <p><strong>COMPLETE SYSTEM COMPROMISE ACHIEVED</strong></p>
            <p style="margin-top: 5px; font-size: 0.9rem;">Stage 5 Complete: All Exploits Chained Successfully</p>
        </div>
    </div>
    
    <div class="flag-box">
        <%= flag %>
    </div>

    <div style="background: rgba(230, 48, 48, 0.1); border: 2px solid var(--primary-red); padding: 20px; border-radius: 0; margin-top: 20px;">
        <p style="color: var(--primary-red); margin: 0; font-weight: 700;">🚨 SECURITY ALERT 🚨</p>
        <p style="color: var(--primary-red); margin: 10px 0 0 0; font-family: var(--font-mono); font-size: 0.9rem;">Network has been compromised. All administrators notified.</p>
    </div>

<% } else { %>
    <div class="error-alert">
        <span class="alert-icon">✗</span>
        <p><strong>Access Denied</strong></p>
    </div>

    <div style="background: rgba(230, 48, 48, 0.05); border: 2px solid var(--primary-red); padding: 20px; border-radius: 0; margin: 20px 0;">
        <p style="margin: 0 0 10px 0; color: var(--primary-red); font-weight: 700;">AUTHENTICATION REQUIRED</p>
        <p style="margin: 0; color: var(--text-main);">
            <%= error %>
        </p>
    </div>

    <div class="hint-text">
        💡 <strong>Challenge:</strong> This is the final stage. You need a forged JWT token with "alg":"none" and admin role. Send it to /admin as a POST request.
    </div>
<% } %>
