<h2 style="text-align: center;">Administrator Control Panel</h2>

<% if (flag) { %>
    <div class="success-alert">
        <span class="alert-icon">SUCCESS</span>
        <div>
            <p><strong>Administrative Access Granted</strong></p>
            <p style="margin-top: 5px; font-size: 0.9rem;">All security certifications verified</p>
        </div>
    </div>
    
    <div class="flag-box">
        <%= flag %>
    </div>

    <div style="background: var(--bg-light); border: 1px solid var(--border-light); padding: 20px; border-radius: 6px; margin-top: 20px;">
        <p style="color: var(--text-dark); margin: 0; font-weight: 700;">System Status: Secured</p>
        <p style="color: var(--text-gray); margin: 10px 0 0 0; font-size: 0.9rem;">All administrators notified of access. Audit log updated.</p>
    </div>

<% } else { %>
    <div class="error-alert">
        <span class="alert-icon">ERROR</span>
        <p><strong>Access Denied</strong></p>
    </div>

    <div style="background: var(--bg-light); border: 1px solid var(--border-light); padding: 20px; border-radius: 6px; margin: 20px 0;">
        <p style="margin: 0 0 10px 0; color: var(--text-dark); font-weight: 700;">Authentication Required</p>
        <p style="margin: 0; color: var(--text-gray);">
            <%= error %>
        </p>
    </div>

    <div class="hint-text">
        <strong>Note:</strong> Only authenticated administrators can access this panel. Please verify your credentials.
    </div>
<% } %>
