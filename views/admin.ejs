<h2 class="glitch" data-text="ADMINISTRATIVE CONTROL" style="text-align: center;">ADMINISTRATIVE CONTROL</h2>

<% if (flag) { %>
    <div class="success-alert">
        <div style="font-family: 'Share Tech Mono', monospace; font-weight: bold;">[ ELEVATED ACCESS VERIFIED ]</div>
        <div style="margin-top: 0.5rem; font-size: 0.9rem; opacity: 0.8;">Root certificate successfully validated. Terminal session encrypted.</div>
    </div>
    
    <div class="flag-box">
        <div style="font-size: 0.8rem; color: var(--flag-amber); margin-bottom: 0.5rem; font-weight: bold; animation: pulse 1s infinite;">🚩 FLAG 5/5 CAPTURED!</div>
        <%= flag %>
    </div>

    <div class="terminal-block" style="margin-top: 2rem;">
        <p style="color: var(--terminal-green); font-weight: bold;">System Status: SECURED</p>
        <p style="color: var(--text-dim); margin-top: 5px; font-size: 0.85rem;">Event: Successful privilege escalation to OMNIVORE-CORE. Audit log entry: #<%= Math.floor(Math.random() * 900000) + 100000 %></p>
    </div>

<% } else { %>
    <div class="error-alert">
        <div style="font-family: 'Share Tech Mono', monospace; font-weight: bold;">[ SYSTEM LOCKOUT ]</div>
        <p style="font-size: 0.85rem; margin-top: 5px;">Insufficient privilege level for requested operation.</p>
    </div>

    <div class="terminal-block" style="margin: 2rem 0;">
        <p style="color: var(--primary-red); font-weight: bold;">Authentication Error</p>
        <p style="margin-top: 10px; color: var(--text-main);">
            <%= error %>
        </p>
    </div>

    <div class="terminal-block" style="border-left: 3px solid var(--flag-amber); color: var(--flag-amber); font-size: 0.85rem;">
        <span style="font-weight: bold;">[ OPERATOR ALERT ]</span> Access attempts are logged by the Omnivore Infrastructure Security Layer. Ensure your SSO token is valid before re-attempting.
    </div>
<% } %>
