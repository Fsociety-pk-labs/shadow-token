<div class="login-container">
    <h2>Enterprise Access Portal</h2>
    <p style="text-align: center; color: var(--terminal-green); font-family: var(--font-mono); margin-bottom: 25px;">Authentication Required</p>

    <% if (flag) { %>
        <div class="success-alert">
            <span class="alert-icon">✓</span>
            <div>
                <p><strong>ACCESS GRANTED</strong></p>
                <p style="margin-top: 5px; font-size: 0.9rem;">Stage 2 Complete: Weak Credentials Exploited</p>
            </div>
        </div>
        <div class="flag-box">
            <%= flag %>
        </div>
    <% } else { %>
        <% if (error) { %>
            <div class="error-alert">
                <span class="alert-icon">✗</span>
                <p><%= error %></p>
            </div>
        <% } %>

        <form action="/login" method="POST" style="margin-top: 20px;">
            <div class="input-group">
                <label for="username">Username</label>
                <input type="text" id="username" name="username" placeholder="••••••••" required autocomplete="off">
            </div>
            <div class="input-group">
                <label for="password">Password</label>
                <input type="password" id="password" name="password" placeholder="••••••••" required>
            </div>
            <button type="submit">AUTHENTICATE</button>
        </form>

        <div class="hint-text" style="margin-top: 20px;">
            💡 <strong>Hint:</strong> Credentials are encoded somewhere in the application. Check network requests and source code.
        </div>
    <% } %>
</div>

<!--
PRIVILEGED INFORMATION:
Credentials are validated through a Base64-encoded hash.
Pattern: base64(username:password)
Look for how credentials are validated in the backend.
Inspect HTTP requests to see what format is expected.
-->

<style>
    .login-container {
        text-align: center;
    }

    .login-container h2 {
        text-align: center;
    }
</style>
