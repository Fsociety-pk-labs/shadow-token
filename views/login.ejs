<div class="login-wrapper" style="max-width: 450px; margin: 0 auto; text-align: center;">
    <h2 class="glitch" data-text="AUTHORIZATION">AUTHORIZATION</h2>
    <p style="color: var(--text-dim); margin-bottom: 2rem; font-family: 'Share Tech Mono', monospace;">SECURE ACCESS PORTAL // LEVEL 4</p>

    <% if (flag) { %>
        <div class="success-alert">
            <div style="font-family: 'Share Tech Mono', monospace; font-weight: bold;">[ ACCESS GRANTED ]</div>
            <div style="margin-top: 0.5rem; font-size: 0.9rem; opacity: 0.8;">Primary directive initialized. Flag retrieved.</div>
        </div>
        <div class="flag-box">
            <div style="font-size: 0.8rem; color: var(--flag-amber); margin-bottom: 0.5rem; font-weight: bold; animation: pulse 1s infinite;">🚩 FLAG 2/5 CAPTURED!</div>
            <%= flag %>
        </div>
    <% } else { %>
        <% if (error) { %>
            <div class="error-alert">
                <span style="font-family: 'Share Tech Mono', monospace; font-weight: bold;">[ ACCESS DENIED ]</span>
                <p style="font-size: 0.85rem; margin-top: 5px;"><%= error %></p>
            </div>
        <% } %>

        <form action="/login" method="POST" style="margin-top: 1rem;">
            <div class="input-group">
                <label for="username">Identity Identifier</label>
                <input type="text" id="username" name="username" placeholder="UID-0000" required autocomplete="off">
            </div>
            <div class="input-group">
                <label for="password">Pass-Key</label>
                <input type="password" id="password" name="password" placeholder="********" required>
            </div>
            <button type="submit">EXECUTE AUTHENTICATION</button>
        </form>

        <div class="terminal-block" style="margin-top: 2rem; padding: 1rem; font-size: 0.8rem; text-align: left;">
            <span style="color: var(--primary-red);">[ NOTICE ]</span> Use enterprise credentials only. Port 80/443 traffic is being monitored at the kernel level by Omnivore Sentinel. Unauthorized access attempts will trigger local lockout.
        </div>
    <% } %>
</div>

<!--
    OPERATOR NOTE:
    The authentication layer uses a Base64-encoded handshake.
    Format: base64(identity:passkey)
    Check application logic for validation pattern.
-->
