<h2 style="text-align: center;">JWT Token Validation Gateway</h2>

<% if (flag) { %>
    <div class="success-alert">
        <span class="alert-icon">✓</span>
        <div>
            <p><strong>CVE-2015-9235 VULNERABILITY EXPLOITED</strong></p>
            <p style="margin-top: 5px; font-size: 0.9rem;">Stage 4 Complete: JWT Algorithm Bypass</p>
        </div>
    </div>
    <div class="flag-box">
        <%= flag %>
    </div>
<% } else { %>
    <div style="background: rgba(0, 255, 65, 0.05); border: 2px solid var(--terminal-green); padding: 15px; border-radius: 0; margin-bottom: 20px;">
        <p style="margin: 0; color: var(--terminal-green); font-family: var(--font-mono); font-size: 0.9rem;">Status: Token Validation Engine Active</p>
    </div>

    <% if (error) { %>
        <div class="error-alert">
            <span class="alert-icon">✗</span>
            <p><%= error %></p>
        </div>
    <% } %>

    <% if (info) { %>
        <div class="info-alert">
            <span class="alert-icon">ℹ</span>
            <p><%= info %></p>
        </div>
    <% } %>

    <form action="/sso" method="POST">
        <div class="input-group">
            <label for="token">JWT Token (Header.Payload.Signature)</label>
            <textarea name="token" id="token" rows="6" required placeholder="Paste JWT here..."><%= jwt %></textarea>
        </div>
        <button type="submit">VALIDATE TOKEN</button>
    </form>

    <div class="code-block" style="margin-top: 20px;">
        <code>Header: { "alg": "HS256", "typ": "JWT" }
Payload: { "role": "guest" }
Signature: [HMAC-SHA256 hash]</code>
    </div>

    <div class="hint-text">
        💡 <strong>Challenge:</strong> What if you change the "alg" field to "none"? Try forging a new JWT with admin role (CVE-2015-9235).
    </div>
<% } %>
