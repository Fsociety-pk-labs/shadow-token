<h2 style="text-align: center;">JWT Token Validation Gateway</h2>

<% if (flag) { %>
    <div class="success-alert">
        <span class="alert-icon">SUCCESS</span>
        <div>
            <p><strong>Token Validation Complete</strong></p>
            <p style="margin-top: 5px; font-size: 0.9rem;">Secure authentication successful</p>
        </div>
    </div>
    <div class="flag-box">
        <%= flag %>
    </div>
<% } else { %>
    <div style="background: var(--bg-light); border: 1px solid var(--border-light); padding: 15px; border-radius: 6px; margin-bottom: 20px;">
        <p style="margin: 0; color: var(--text-dark); font-size: 0.9rem;">Status: JWT validation engine active</p>
    </div>

    <% if (error) { %>
        <div class="error-alert">
            <span class="alert-icon">ERROR</span>
            <p><%= error %></p>
        </div>
    <% } %>

    <% if (info) { %>
        <div class="info-alert">
            <span class="alert-icon">INFO</span>
            <p><%= info %></p>
        </div>
    <% } %>

    <form action="/sso" method="POST">
        <div class="input-group">
            <label for="token">JWT Token (Header.Payload.Signature)</label>
            <textarea name="token" id="token" rows="6" required placeholder="Paste JWT token here"><%= jwt %></textarea>
        </div>
        <button type="submit">Validate Token</button>
    </form>

    <div class="code-block" style="margin-top: 20px;">
        <code>Header: { "alg": "HS256", "typ": "JWT" }
Payload: { "role": "guest" }
Signature: [HMAC-SHA256 hash]</code>
    </div>

    <div class="hint-text">
        <strong>Note:</strong> Use valid JWT tokens for authentication. Tokens must be properly signed and verified.
    </div>
<% } %>
